# Uploaded user files — never commit these
static/uploads/*
!static/uploads/.gitkeep

# Backup archives — private data, never commit
backups/

# Runtime data — private data, never commit
data/

# SQLite database
*.db
*.db-shm
*.db-wal

# Python cache
__pycache__/
*.py[cod]

# Virtual environment
venv/
.venv/

# Environment / secrets
.env
.env.*

# OS junk
.DS_Store
Thumbs.db
