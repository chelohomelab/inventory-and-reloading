[Unit]
Description=Firearm Inventory & Reloading App
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/inventory-and-reloading
ExecStart=/opt/inventory-and-reloading/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
